{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread",
      "Serilog.Expressions"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": {
            "type": "Serilog.Templates.ExpressionTemplate, Serilog.Expressions",
            "template": "[{@t:HH:mm:ss} {@l:u3}] {SourceContext}{#if UserId is not null} (User:{UserId}){#end} {@m}\n{@x}"
          }
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/trading-journal-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "formatter": {
            "type": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
          }
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "TradingJournal"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://trading-journal-ui-eight.vercel.app"
    ]
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 120,
      "WindowMinutes": 1
    },
    "Auth": {
      "PermitLimit": 5,
      "WindowMinutes": 15
    }
  },
  "ConnectionStrings": {
    "TradeDatabase": "REPLACE_IN_CD"
  },
  "Jwt": {
    "Secret": "REPLACE_IN_CD",
    "Issuer": "TradingJournal",
    "Audience": "TradingJournal",
    "ExpiryMinutes": 60
  },
  "OpenRouterAI": {
    "ApiKey": "REPLACE_IN_CD",
    "Model": "REPLACE_IN_CD",
    "BaseUrl": "https://openrouter.ai/api/v1"
  },
  "TwelveData": {
    "ApiKey": "REPLACE_IN_CD"
  }
}
