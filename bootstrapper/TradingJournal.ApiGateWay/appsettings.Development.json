{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": {
            "type": "Serilog.Templates.ExpressionTemplate, Serilog.Expressions",
            "template": "[{@t:HH:mm:ss} {@l:u3}] {SourceContext}{#if UserId is not null} (User:{UserId}){#end} {@m}\n{@x}"
          }
        }
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://trading-journal-ui-nine.vercel.app"
    ]
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 120,
      "WindowMinutes": 1
    },
    "Auth": {
      "PermitLimit": 5,
      "WindowMinutes": 15
    }
  },
  "ConnectionStrings": {
    "TradeDatabase": "Data Source=DESKTOP-BLQN21U\\MSSQLSERVER01;Initial Catalog=Trading_Journal;Integrated Security=True;Persist Security Info=False;Pooling=False;Multiple Active Result Sets=False;Encrypt=True;Trust Server Certificate=True;Command Timeout=0"
  },
  "Jwt": {
    "Secret": "REPLACE_IN_CD",
    "Issuer": "TradingJournal",
    "Audience": "TradingJournal",
    "ExpiryMinutes": 60
  },
  "OpenRouterAI": {
    "ApiKey": "REPLACE_IN_CD",
    "Model": "tencent/hy3-preview:free",
    "BaseUrl": "https://openrouter.ai"
  },
  "TwelveData": {
    "ApiKey": "REPLACE_IN_CD"
  }
}
